# bootstrap vault 明文模板（示例，不要提交真实文件）
# 真实 vault 由 create_vault.sh 生成 bootstrap.vault.age。

DOTFILES_SLUG="Zpwww/dotfiles"
GITHUB_USERNAME="Zpwww"

# GitHub fine-grained token：只给 Zpwww/dotfiles 单仓，Contents Read-only。
GITHUB_TOKEN="github_pat_xxx"

# ~/.config/chezmoi/key.txt 的 base64 内容，由 create_vault.sh 自动生成。
AGE_IDENTITY_B64="base64_of_age_identity_key"

# 可选：Clash 代理订阅 URL。
PROXY_CLASH_URL=""

# 可选：Shadowrocket & Hiddify 代理订阅 URL。
PROXY_SHADOWROCKET_URL=""

# 可选：Tabby 终端的 Gist 同步 Token。由 create_vault.sh 自动从本地读取或手动录入。
TABBY_TOKEN=""
